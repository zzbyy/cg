#!/usr/bin/env python3
"""
Check for open conflicts that should be surfaced at session start or before writes.

Outputs one token per line:
  CLEAR               — nothing pending
  CHECKPOINT_OPEN     — scratchpad/checkpoint.md exists
  INBOX_<N>           — N items in inbox/
  UNCOMMITTED_CHANGES — context repo has unstaged/staged changes
  GIT_NOT_FOUND       — git binary not available
"""
import sys
import os
import subprocess

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import cg_lib

issues = []

if cg_lib.checkpoint_exists():
    issues.append("CHECKPOINT_OPEN")

n = cg_lib.count_inbox()
if n > 0:
    issues.append(f"INBOX_{n}")

try:
    result = subprocess.run(
        ['git', 'status', '--porcelain'],
        capture_output=True, text=True,
        cwd=cg_lib.CONTEXT_ROOT
    )
    if result.returncode == 0 and result.stdout.strip():
        issues.append("UNCOMMITTED_CHANGES")
except FileNotFoundError:
    issues.append("GIT_NOT_FOUND")

if issues:
    for issue in issues:
        print(issue)
else:
    print("CLEAR")
